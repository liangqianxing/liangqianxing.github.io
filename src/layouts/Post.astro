---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  hasToc?: boolean;
}

const { title, description, hasToc = false } = Astro.props;
---
<Base title={title} description={description}>
  <div class={hasToc ? 'post-with-toc' : ''}>
    <main class="shell">
      <article class="prose dark:prose-invert">
        <slot />
      </article>
    </main>
  </div>
</Base>

<style is:global>
  .prose {
    max-width: 100%;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.82;
  }
  .prose :where(h1) {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 2.35rem;
    margin-bottom: 0.95rem;
  }
  .prose :where(h2) {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2.15rem;
    margin-bottom: 0.7rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
  }
  .prose :where(h3) {
    font-size: 1.08rem;
    font-weight: 600;
    margin-top: 1.6rem;
    margin-bottom: 0.55rem;
  }
  .prose :where(h4) {
    font-size: 0.98rem;
    font-weight: 600;
    margin-top: 1.4rem;
    margin-bottom: 0.45rem;
    color: var(--text-soft);
  }
  .prose :where(p) { margin: 0.95rem 0; }
  .prose :where(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .prose :where(a):hover {
    border-bottom-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .prose :where(strong) { color: var(--text); font-weight: 600; }
  .prose :where(blockquote) {
    margin: 1.25rem 0;
    padding: 0.65rem 1.1rem;
    border-left: 3px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    color: var(--text-soft);
    font-style: normal;
    border-radius: 0 4px 4px 0;
  }
  .prose :where(blockquote) :where(p) { margin: 0.4rem 0; }
  .prose :where(ul), .prose :where(ol) { padding-left: 1.4rem; margin: 0.85rem 0; }
  .prose :where(li) { margin: 0.35rem 0; }
  .prose :where(li)::marker { color: var(--text-mute); }
  .prose :where(hr) { border-top: 1px solid var(--line); margin: 2rem 0; }
  .prose :where(img) {
    border-radius: 6px;
    margin: 1.5rem auto;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
  }
  .prose :where(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.92em;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .prose :where(th), .prose :where(td) {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--line);
    text-align: left;
  }
  .prose :where(th) {
    font-weight: 600;
    color: var(--text);
    background: var(--bg-soft);
  }

  .prose :where(code):not(:where(pre code)) {
    background: color-mix(in srgb, var(--accent) 9%, var(--surface));
    color: var(--accent);
    padding: 0.12em 0.4em;
    border-radius: 4px;
    font-size: 0.86em;
    font-family: var(--font-mono);
    border: 1px solid var(--line-soft);
  }
  .prose :where(pre) {
    background: var(--code-bg);
    color: var(--code-text);
    padding: 1rem 1.15rem;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.86em;
    line-height: 1.7;
    margin: 1.25rem 0;
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    box-shadow: var(--shadow-md);
  }
  html.dark .prose :where(pre) {
    background: var(--code-bg);
    border: 1px solid var(--line);
  }
  .prose :where(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    border: 0;
    font-size: inherit;
  }

  .prose h2 a, .prose h3 a, .prose h4 a {
    border: 0;
    background: transparent;
  }
  .prose h2 a:hover, .prose h3 a:hover, .prose h4 a:hover {
    background: transparent;
  }
</style>
