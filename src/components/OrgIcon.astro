---
interface Props {
  name: string;
  size?: number;
}

const { name, size = 26 } = Astro.props;

const logoMap: Record<string, string> = {
  '美团': '/logos/meituan.svg',
  'Meituan': '/logos/meituan.svg',
  'vivo': '/logos/vivo.svg',
  '西湖大学': '/logos/westlake.png',
  '中南大学': '/logos/csu.jpg',
  '新疆大学': '/logos/xju.jpg',
};

const src = logoMap[name];
---
{src ? (
  <img
    src={src}
    alt={`${name} logo`}
    width={size}
    height={size}
    loading="lazy"
    decoding="async"
    class="org-logo"
  />
) : (
  <svg width={size * 0.65} height={size * 0.65} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="7" width="18" height="13" rx="2" />
    <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
    <path d="M3 13h18" />
  </svg>
)}
