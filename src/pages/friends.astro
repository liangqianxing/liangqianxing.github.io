---
import Base from '../layouts/Base.astro';
import { siteConfig } from '../lib/site';

const friends = siteConfig.friends;
const rings = siteConfig.rings;

const initial = (name: string) => (name.trim()[0] ?? '?').toUpperCase();
---
<Base title="友链 · 左邻右舍" description="朋友们的博客与友链接力。">
  <div class="shell-wide">
    <header class="friends-hero">
      <div class="friends-eyebrow">FRIENDS · 左邻右舍</div>
      <h1 class="friends-title">朋友们</h1>
      <p class="friends-quote">海内存知己，天涯若比邻。</p>
    </header>

    <section class="friends-section">
      <div class="section-eyebrow">
        <h2>友链接力</h2>
        <a href="https://www.travellings.cn/" class="more" target="_blank" rel="noreferrer noopener">了解 →</a>
      </div>
      <p class="friends-section-desc">点击下面的按钮，会随机带你前往下一个朋友的博客。</p>
      <div class="ring-grid">
        {rings.map((r) => (
          <a href={r.url} target="_blank" rel="noreferrer noopener" class="ring-card" title={`${r.name} · ${r.desc}`}>
            <div class="ring-logo">
              <img src={r.logo} alt={`${r.name} logo`} loading="lazy" decoding="async" />
            </div>
            <div class="ring-body">
              <div class="ring-name">{r.name}<span class="ring-arrow">→</span></div>
              <div class="ring-desc">{r.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="friends-section">
      <div class="section-eyebrow">
        <h2>朋友们</h2>
        <span class="more" style="cursor:default;">{friends.length} 位</span>
      </div>
      <ul class="friend-list">
        {friends.map((f) => (
          <li>
            <a href={f.url} target="_blank" rel="noreferrer noopener" class="friend-tile" title={f.desc ?? f.name}>
              <div class="friend-tile-avatar">
                {f.avatar ? (
                  <img src={f.avatar} alt={`${f.name} avatar`} loading="lazy" decoding="async" onerror="this.replaceWith(Object.assign(document.createElement('span'),{textContent:this.alt[0]?.toUpperCase()??'?',className:'friend-tile-fallback'}))" />
                ) : (
                  <span class="friend-tile-fallback">{initial(f.name)}</span>
                )}
              </div>
              <div class="friend-tile-name">{f.name}</div>
              {f.desc && <div class="friend-tile-desc">{f.desc}</div>}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="friends-section">
      <div class="section-eyebrow">
        <h2>申请友链</h2>
      </div>
      <div class="apply-box">
        <p class="apply-intro">欢迎来交换友链。把下面的格式发到 <a href={siteConfig.social.github} target="_blank" rel="noreferrer noopener" class="text-link">GitHub Issues</a>，或在任意文章下留言：</p>
        <pre class="apply-snippet"><code>{`名称：${siteConfig.author}
链接：${siteConfig.url}
头像：${siteConfig.url}/favicon.svg
描述：${siteConfig.description}`}</code></pre>
        <p class="apply-tip">交换前请确保你的站点已添加我的链接，并且能稳定访问 ✨</p>
      </div>
    </section>
  </div>
</Base>
