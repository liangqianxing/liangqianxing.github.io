---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { tagSlug } from '../../lib/posts';

const posts = await getCollection('posts');
const counts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    counts.set(t, (counts.get(t) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<Base title="标签" description="按标签浏览全部文章。">
  <div class="shell">
    <header class="mb-8">
      <h1 class="m-0 text-[1.6rem] font-semibold tracking-tight" style="font-family: var(--font-serif);">标签</h1>
      <p class="mt-2 text-[14px]" style="color: var(--text-mute);">共 {tags.length} 个标签 · {posts.length} 篇文章</p>
    </header>

    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => (
        <a href={`/tags/${encodeURIComponent(tagSlug(tag))}`} class="tag-chip">
          <span>{tag}</span>
          <span class="count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</Base>
