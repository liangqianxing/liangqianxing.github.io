---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatMonthDay, sortPosts } from '../../lib/posts';

const posts = sortPosts(await getCollection('posts'));
const groups = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = String(post.data.date.getFullYear());
  acc[year] ??= [];
  acc[year].push(post);
  return acc;
}, {});
const sortedYears = Object.keys(groups).sort((a, b) => Number(b) - Number(a));
---
<Base title="文章" description="所有文章按年份归档。">
  <div class="shell">
    <header class="mb-8">
      <h1 class="m-0 text-[1.6rem] font-semibold tracking-tight" style="font-family: var(--font-serif);">文章</h1>
      <p class="mt-2 text-[14px]" style="color: var(--text-mute);">共 {posts.length} 篇 · 按年份归档</p>
    </header>

    {sortedYears.map((year) => (
      <section class="year-block">
        <h2 class="year-label">{year}<span class="year-count">{groups[year].length}</span></h2>
        <div>
          {groups[year].map((post) => (
            <a href={`/posts/${post.slug}`} class="post-row">
              <time class="post-row-date" datetime={post.data.date.toISOString()}>{formatMonthDay(post.data.date)}</time>
              <span class="post-row-title">{post.data.title}</span>
              {post.data.tags && post.data.tags[0] && <span class="post-row-tag">{post.data.tags[0]}</span>}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
