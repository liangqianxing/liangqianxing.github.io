---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { siteConfig } from '../lib/site';
import { filterDrafts, formatMonthDay, readingTime, sortPosts } from '../lib/posts';

const posts = sortPosts(filterDrafts(await getCollection('posts')));
const recent = posts.slice(0, siteConfig.postsPerHomepage);
const featured = recent[0];
const showcase = recent.slice(1, 4);
const rest = recent.slice(4);
const totalPosts = posts.length;

const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
---
<Base>
  <div class="shell-wide">

    <!-- ─── 英雄区：个人介绍 ──────────────────────────────────────── -->
    <section class="hero-personal">
      <div class="hero-eyebrow">
        <span class="hero-dot" aria-hidden="true"></span>
        <span class="hero-status">正在美团实习 · 新疆大学在读</span>
      </div>
      <h1 class="hero-name">
        <span class="hero-name-cn">{siteConfig.authorCN}</span>
        <span class="hero-name-sep" aria-hidden="true">/</span>
        <span class="hero-name-en">{siteConfig.authorEN}</span>
      </h1>
      <p class="hero-bio">{siteConfig.bio}</p>
      <div class="hero-links">
        <a href="/posts" class="hero-link-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 6h16M4 10h16M4 14h8"/></svg>
          {totalPosts} 篇文章
        </a>
        <a href={siteConfig.social.github} target="_blank" rel="noreferrer noopener" class="hero-link-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.69-3.87-1.35-3.87-1.35-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.66.8.55C20.22 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
          GitHub
        </a>
        <a href="/rss.xml" class="hero-link-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor"/></svg>
          RSS
        </a>
        <a href="/about" class="hero-link-pill">
          关于我 →
        </a>
      </div>
    </section>

    <!-- ─── 最新文章 ─────────────────────────────────────────────── -->
    {featured && (
      <article class="mt-2">
        <div class="section-eyebrow">
          <h2>最新</h2>
          <a href={`/posts/${featured.slug}`} class="more">阅读全文 →</a>
        </div>
        <a href={`/posts/${featured.slug}`} class="featured-card group">
          <div class="featured-body">
            <h3 class="featured-title">{featured.data.title}</h3>
            {featured.data.description && <p class="featured-desc">{featured.data.description}</p>}
            <div class="featured-meta">
              <time datetime={featured.data.date.toISOString()}>{featured.data.date.getFullYear()}-{formatMonthDay(featured.data.date)}</time>
              <span>·</span>
              <span>{readingTime(featured.body)} min read</span>
              {featured.data.tags && featured.data.tags.length > 0 && <>
                <span>·</span>
                <span>{featured.data.tags.slice(0, 3).join(' / ')}</span>
              </>}
            </div>
          </div>
        </a>
      </article>
    )}

    <!-- ─── 精选 ───────────────────────────────────────────────── -->
    {showcase.length > 0 && (
      <section>
        <div class="section-eyebrow">
          <h2>精选</h2>
          <a href="/posts" class="more">归档 →</a>
        </div>
        <div class="showcase-grid">
          {showcase.map((post) => (
            <a href={`/posts/${post.slug}`} class="showcase-card">
              <div class="showcase-body">
                <time class="showcase-date" datetime={post.data.date.toISOString()}>{post.data.date.getFullYear()}-{formatMonthDay(post.data.date)}</time>
                <h3 class="showcase-title">{post.data.title}</h3>
                {post.data.tags && post.data.tags[0] && <span class="showcase-tag">{post.data.tags[0]}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ─── 更多 ───────────────────────────────────────────────── -->
    {rest.length > 0 && (
      <section>
        <div class="section-eyebrow">
          <h2>更多</h2>
          <a href="/posts" class="more">全部 →</a>
        </div>
        <div>
          {rest.map((post) => (
            <a href={`/posts/${post.slug}`} class="post-row">
              <time class="post-row-date" datetime={post.data.date.toISOString()}>{formatMonthDay(post.data.date)}</time>
              <span class="post-row-title">{post.data.title}</span>
              {post.data.tags && post.data.tags[0] && <span class="post-row-tag">{post.data.tags[0]}</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ─── 标签云 ─────────────────────────────────────────────── -->
    {topTags.length > 0 && (
      <section>
        <div class="section-eyebrow">
          <h2>标签</h2>
          <a href="/tags" class="more">全部 →</a>
        </div>
        <div class="flex flex-wrap gap-2 py-1">
          {topTags.map(([tag, count]) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-chip">
              <span>{tag}</span>
              <span class="count">{count}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
