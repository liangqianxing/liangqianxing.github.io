<% const isHome = page.path === 'index.html' || page.path === '' %>
<% if (isHome) { %>
<%- partial('_partial/homepage') %>
<% } else { %>
<% const posts = (page.posts && page.posts.length) ? page.posts : site.posts.sort('date', -1) %>
<div class="blog-page">
  <div class="blog-header">
    <div class="section-inner blog-header-inner">
      <h1 class="blog-title">博<span class="blog-title-accent">客</span></h1>
      <p class="blog-subtitle">记录技术与生活的点滴</p>
      <div class="blog-stats">
        <span class="blog-stat">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span class="blog-stat-num"><%= site.posts.length %></span> 篇文章
        </span>
      </div>
    </div>
  </div>
  <div class="section-inner">
    <div class="post-grid">
      <% posts.each(post => { %>
      <article class="post-card">
        <div class="post-card-body">
          <div class="post-card-meta">
            <time class="post-date"><%= post.date.format('YYYY-MM-DD') %></time>
            <% if (post.categories && post.categories.length) { %>
            <span class="post-category"><%= post.categories.toArray()[0].name %></span>
            <% } %>
          </div>
          <h2 class="post-card-title">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </h2>
          <p class="post-card-excerpt"><%= post.excerpt ? strip_html(post.excerpt).substring(0, 120) : strip_html(post.content).substring(0, 120) %>...</p>
        </div>
        <div class="post-card-footer">
          <% if (post.tags && post.tags.length) { %>
          <div class="post-tags">
            <% post.tags.toArray().slice(0, 3).forEach(tag => { %>
            <span class="post-tag"># <%= tag.name %></span>
            <% }) %>
          </div>
          <% } %>
          <a href="<%- url_for(post.path) %>" class="post-read-more">阅读 →</a>
        </div>
      </article>
      <% }) %>
    </div>
    <%- partial('_partial/pagination') %>
  </div>
</div>
<% } %>
