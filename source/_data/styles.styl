// ============================================================
// Polished custom theme for Hexo NexT (Pisces)
// ============================================================

:root
  --bg-start #f7faff
  --bg-end #edf3ff
  --surface rgba(255, 255, 255, .78)
  --surface-strong rgba(255, 255, 255, .9)
  --line rgba(42, 88, 160, .14)
  --line-strong rgba(42, 88, 160, .26)
  --text-main #15253b
  --text-sub #5f7088
  --accent #2f74d0
  --accent-2 #11b8a3
  --radius-xl 20px
  --radius-md 14px
  --shadow-soft 0 16px 42px rgba(17, 41, 78, .14)
  --shadow-card 0 12px 32px rgba(12, 30, 61, .11)

:root[data-theme-effective='dark']
  --bg-start #0b1222
  --bg-end #131b30
  --surface rgba(16, 25, 43, .7)
  --surface-strong rgba(18, 30, 52, .86)
  --line rgba(139, 176, 228, .22)
  --line-strong rgba(139, 176, 228, .36)
  --text-main #e8efff
  --text-sub #a6b9d8
  --accent #7db8ff
  --accent-2 #40e0c5
  --shadow-soft 0 16px 48px rgba(2, 7, 18, .52)
  --shadow-card 0 14px 34px rgba(2, 7, 18, .42)

html,
body
  min-height 100%

body
  font-family "Avenir Next", "Space Grotesk", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif
  color var(--text-main)
  background linear-gradient(155deg, var(--bg-start), var(--bg-end)) fixed
  letter-spacing .01em

body::before,
body::after
  content ''
  position fixed
  pointer-events none
  z-index 0
  filter blur(36px)

body::before
  width 38vw
  height 38vw
  left -10vw
  top -13vh
  border-radius 999px
  background radial-gradient(circle, rgba(47, 116, 208, .22), rgba(47, 116, 208, 0) 68%)

body::after
  width 34vw
  height 34vw
  right -12vw
  top 12vh
  border-radius 999px
  background radial-gradient(circle, rgba(17, 184, 163, .2), rgba(17, 184, 163, 0) 70%)

.main,
.header,
.footer,
.back-to-top,
.sidebar-toggle
  position relative
  z-index 1

.headband
  height 4px
  background linear-gradient(90deg, rgba(17, 184, 163, 0), rgba(17, 184, 163, .86), rgba(47, 116, 208, .92), rgba(47, 116, 208, 0))

.site-brand-container,
.site-nav,
.main-inner,
.sidebar-inner,
.post-block,
.post-toc-wrap,
.graph-panel,
.graph-preview,
.graph-list,
.footer-inner
  background var(--surface)
  border 1px solid var(--line)
  border-radius var(--radius-xl)
  box-shadow var(--shadow-card)
  backdrop-filter blur(12px) saturate(112%)

.main-inner
  padding 32px 30px

.site-brand-container
  margin-bottom 12px
  padding 10px 14px
  background var(--surface-strong)

.site-title
  font-weight 780
  letter-spacing .02em
  color var(--text-main) !important

.site-subtitle
  color var(--text-sub)

.site-nav
  padding 6px 8px

.main-menu.menu
  display flex
  flex-wrap wrap
  gap .38rem

.main-menu .menu-item a
  border-radius 12px
  border 1px solid transparent
  color var(--text-sub) !important
  padding 7px 12px !important
  transition all .22s ease

.main-menu .menu-item a:hover,
.main-menu .menu-item-active a
  color #fff !important
  border-color transparent
  background linear-gradient(135deg, var(--accent), var(--accent-2)) !important
  box-shadow 0 10px 20px rgba(18, 70, 141, .22)

.menu-item-theme-toggle a
  min-width 92px
  justify-content center
  display inline-flex !important
  align-items center
  gap 7px
  background rgba(47, 116, 208, .08)
  border 1px solid var(--line-strong) !important
  color var(--accent) !important

.menu-item-theme-toggle.is-dark a
  background linear-gradient(135deg, rgba(125, 184, 255, .2), rgba(64, 224, 197, .22)) !important
  color var(--text-main) !important

.menu-item-theme-toggle .theme-menu-icon
  transition transform .22s ease

.menu-item-theme-toggle a:hover .theme-menu-icon
  transform rotate(-14deg)

.home-hero
  margin 0 auto 2.2rem
  padding 2.4rem
  border-radius 24px
  border 1px solid rgba(255, 255, 255, .2)
  box-shadow var(--shadow-soft)
  color #fff
  background linear-gradient(132deg, rgba(47, 116, 208, .96), rgba(17, 184, 163, .92) 72%)
  position relative
  overflow hidden

.home-hero::after
  content ''
  position absolute
  width 280px
  height 280px
  border-radius 999px
  right -60px
  top -90px
  background radial-gradient(circle, rgba(255, 255, 255, .3), rgba(255, 255, 255, 0) 72%)

.home-hero > *
  position relative
  z-index 1

.home-hero__eyebrow
  text-transform uppercase
  letter-spacing .22em
  font-size .82rem
  opacity .86

.home-hero__title
  margin .95rem 0
  font-size clamp(1.9rem, 5vw, 2.65rem)
  line-height 1.2

.home-hero__subtitle
  max-width 44rem
  font-size 1.05rem
  opacity .92

.home-hero__actions
  margin-top 1.4rem
  display flex
  flex-wrap wrap
  gap .85rem

.hero-btn,
.ghost-btn
  border-radius 999px
  padding .75rem 1.35rem
  font-weight 620
  border 1px solid transparent
  transition all .22s ease

.hero-btn
  background #fff
  color #163052
  box-shadow 0 10px 24px rgba(15, 33, 58, .2)

.hero-btn:hover
  transform translateY(-1px)

.ghost-btn
  color #fff
  border-color rgba(255, 255, 255, .6)
  background rgba(255, 255, 255, .1)

.ghost-btn:hover
  background rgba(255, 255, 255, .2)

.post-block
  padding 2rem
  margin-bottom 1.6rem

.post-header
  margin-bottom 1.2rem

.post-title,
.post-title-link
  font-weight 760
  color var(--text-main) !important

.post-meta
  color var(--text-sub)

.post-body
  font-size 1.04rem
  line-height 1.88
  color var(--text-main)

.post-body p,
.post-body li,
.post-body td
  color var(--text-main)

.post-body h2,
.post-body h3,
.post-body h4
  color var(--text-main)
  font-weight 730

.post-body h2::after
  content ''
  display block
  width 52px
  height 4px
  margin-top .56rem
  border-radius 999px
  background linear-gradient(135deg, var(--accent), var(--accent-2))

.post-body a
  color var(--accent)
  border-bottom 1px solid rgba(47, 116, 208, .3)
  transition color .2s ease, border-color .2s ease

.post-body a:hover
  color var(--accent-2)
  border-color rgba(17, 184, 163, .55)

.post-body code
  color var(--text-main)
  background rgba(42, 88, 160, .12)
  border-radius 7px
  padding .16rem .42rem

.post-body pre,
.post-body figure.highlight
  border 1px solid var(--line)
  border-radius 14px
  box-shadow none
  overflow auto

.post-body blockquote
  margin 1.5rem 0
  padding 1rem 1.2rem
  border-radius 0 12px 12px 0
  border-left 3px solid rgba(47, 116, 208, .7)
  background rgba(47, 116, 208, .09)

.post-body img
  border-radius 16px
  box-shadow var(--shadow-card)

.post-body table
  border-radius 14px
  overflow hidden
  border 1px solid var(--line)

.post-body tbody tr + tr
  border-top 1px solid rgba(42, 88, 160, .1)

.post-tags a,
.tag-cloud a
  border-radius 999px
  border 1px solid rgba(47, 116, 208, .28)
  color var(--accent)
  transition all .2s ease

.post-tags a:hover,
.tag-cloud a:hover
  color #fff
  background linear-gradient(135deg, var(--accent), var(--accent-2))
  border-color transparent

.post-toc-wrap
  border-radius 16px
  padding 1.1rem 1.2rem

.post-toc-title
  color var(--text-sub)
  text-transform uppercase
  letter-spacing .08em
  font-size .84rem

.post-toc .nav-item
  transition transform .2s ease, color .2s ease

.post-toc .nav-item:hover
  transform translateX(2px)

.sidebar-inner
  padding 1.2rem

.site-author-image
  border-radius 18px
  border 2px solid rgba(255, 255, 255, .78)
  box-shadow 0 10px 28px rgba(15, 36, 71, .17)

.site-author-name
  font-weight 720

.site-description,
.site-state-item-count,
.site-state-item-name,
.links-of-author-item a,
.links-of-blogroll-item a
  color var(--text-sub) !important

.site-state-item a,
.links-of-author-item a,
.links-of-blogroll-item a
  border-radius 10px
  border 1px solid transparent
  padding 4px 8px
  transition all .2s ease

.site-state-item a:hover,
.links-of-author-item a:hover,
.links-of-blogroll-item a:hover
  border-color var(--line-strong)
  color var(--accent) !important
  background rgba(47, 116, 208, .08)

.footer
  margin-top 24px

.footer-inner
  padding 14px 18px
  display inline-flex
  width auto
  max-width calc(100% - 18px)

.footer-inner,
.footer-inner a,
.powered-by,
.copyright
  color var(--text-sub) !important

.back-to-top,
.sidebar-toggle
  width 40px
  height 40px
  border-radius 12px
  border 1px solid var(--line)
  box-shadow var(--shadow-card)
  background var(--surface-strong) !important
  color var(--accent) !important

.back-to-top:hover,
.sidebar-toggle:hover
  transform translateY(-1px)

::selection
  background rgba(47, 116, 208, .3)
  color var(--text-main)

::-webkit-scrollbar
  width 10px
  height 10px

::-webkit-scrollbar-thumb
  background linear-gradient(180deg, rgba(47, 116, 208, .72), rgba(17, 184, 163, .72))
  border-radius 999px

::-webkit-scrollbar-track
  background rgba(42, 88, 160, .12)

.post-body.category-graph-body
  max-width none
  margin 0
  padding-top .4rem

.graph-lite-guides
  margin 1.2rem 0 1rem
  padding .95rem 1.05rem
  border-radius var(--radius-md)
  border 1px solid var(--line)
  background rgba(47, 116, 208, .08)
  display flex
  justify-content space-between
  align-items center
  gap .8rem

.graph-lite-text
  margin 0
  color var(--text-main)

.graph-lite-stats
  display flex
  flex-wrap wrap
  gap .6rem
  color var(--text-sub)

.graph-lite-stats span
  border-radius 999px
  border 1px solid var(--line)
  background var(--surface-strong)
  padding .3rem .72rem

.category-graph-grid
  display grid
  grid-template-columns minmax(0, 1.28fr) minmax(280px, .84fr)
  gap 1.25rem
  align-items stretch

.graph-panel,
.graph-preview,
.graph-list
  padding 1.35rem

.graph-panel--full
  padding-bottom 1.9rem

.graph-panel__header
  margin-bottom 1rem

.graph-panel__eyebrow
  margin 0 0 .55rem
  letter-spacing .26em
  text-transform uppercase
  font-size .72rem
  color var(--accent-2)

.graph-panel__title
  margin .1rem 0 .35rem
  color var(--text-main)

.graph-panel__desc
  margin 0
  color var(--text-sub)

.graph-selection
  margin-top .72rem
  border-radius 12px
  border 1px solid var(--line)
  background rgba(47, 116, 208, .09)
  color var(--text-main)
  padding .6rem .84rem
  display flex
  flex-wrap wrap
  gap .7rem

.graph-canvas
  min-height 540px
  border-radius 16px
  border 1px solid var(--line)
  background radial-gradient(circle at 25% 15%, rgba(47, 116, 208, .13), transparent 42%), radial-gradient(circle at 85% 65%, rgba(17, 184, 163, .12), transparent 38%), linear-gradient(145deg, rgba(47, 116, 208, .07), rgba(17, 184, 163, .05))
  overflow hidden

.graph-canvas svg
  width 100%
  height 100%

.graph-preview
  position sticky
  top 86px
  max-height 720px
  overflow auto

.graph-preview__header
  margin-bottom .92rem
  display flex
  flex-direction column
  gap .35rem

.graph-preview__link
  width fit-content
  border-radius 999px
  border 1px solid rgba(47, 116, 208, .32)
  padding .42rem .92rem
  color var(--accent)
  text-decoration none
  transition all .2s ease

.graph-preview__link:hover
  color #fff
  background linear-gradient(135deg, var(--accent), var(--accent-2))
  border-color transparent

.graph-preview__link.is-disabled
  opacity .45
  pointer-events none

.graph-post-items
  list-style none
  margin 0
  padding 0
  display flex
  flex-direction column
  gap .7rem

.graph-post-item
  border-radius 12px
  border 1px solid var(--line)
  background rgba(47, 116, 208, .06)
  padding .72rem .85rem
  display flex
  flex-direction column
  gap .24rem
  transition transform .18s ease, border-color .18s ease

.graph-post-item:hover
  transform translateY(-1px)
  border-color var(--line-strong)

.graph-post-item a
  color var(--accent)
  font-weight 620
  text-decoration none

.graph-post-item span
  color var(--text-sub)
  font-size .86rem

.graph-post-item--empty
  text-align center
  color var(--text-sub)

.graph-links line
  stroke rgba(47, 116, 208, .24)
  stroke-width 2

.graph-node circle
  fill var(--surface-strong)
  stroke var(--accent)
  stroke-width 2.6
  transition transform .2s ease, stroke .2s ease

.graph-node text
  fill var(--text-main)
  font-size .88rem
  paint-order stroke
  stroke rgba(255, 255, 255, .78)
  stroke-width 1.7px
  pointer-events none

:root[data-theme-effective='dark'] .graph-node text
  stroke rgba(6, 12, 23, .75)

.graph-node.is-active circle,
.graph-node:hover circle
  stroke var(--accent-2)
  transform scale(1.04)

.graph-empty
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  color var(--text-sub)

@media (max-width: 991px)
  .main-inner
    padding 24px 18px

  .category-graph-grid
    grid-template-columns 1fr

  .graph-preview
    position static
    max-height none

@media (max-width: 768px)
  body::before,
  body::after
    display none

  .home-hero
    padding 1.75rem

  .home-hero__actions
    flex-direction column
    align-items flex-start

  .post-block
    padding 1.35rem

  .footer-inner
    display block
    text-align center

  .graph-canvas
    min-height 370px

  .graph-lite-guides
    flex-direction column
    align-items flex-start

  .main-menu.menu
    flex-wrap nowrap
    overflow-x auto
    scrollbar-width none

  .main-menu.menu::-webkit-scrollbar
    display none
